{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mado",
  "version": "0.1.0",
  "identifier": "dev.hajime.mado",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mado",
        "width": 460,
        "height": 560,
        "minWidth": 340,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
